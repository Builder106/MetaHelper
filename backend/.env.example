# MetaHelper backend configuration
# Copy this file to `.env` and fill in your values. Never commit `.env`.

# Google Gemini API key — required.
# Create one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Optional: playback gain applied to synthesized speech (0.0–1.0).
# Lower values quiet the audio so it doesn't overpower the glasses' speakers.
# Defaults to 0.1 if unset.
AUDIO_AMPLITUDE_MULTIPLIER=0.1
